generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  subjects      Subject[]
  studySessions StudySession[]
  questions     Question[]
  topics        Topic[]
  attachments   TopicAttachment[]
  settings      Setting[]
}

model Subject {
  id          String    @id @default(cuid())
  userId      String
  name        String
  color       String    @default("#6366f1")
  goalMinutes Int       @default(60)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    StudySession[]
  questions   Question[]
  topics      Topic[]
}

model StudySession {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String?
  minutes     Int
  sessionType String   @default("timer")
  notes       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Question {
  id        String   @id @default(cuid())
  userId    String
  subjectId String?
  topic     String?
  total     Int      @default(0)
  correct   Int      @default(0)
  wrong     Int      @default(0)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Topic {
  id          String    @id @default(cuid())
  userId      String
  subjectId   String?
  name        String
  studyDate   DateTime?
  completed   Boolean   @default(false)
  source      String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     Subject?  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  attachments TopicAttachment[]
}

model TopicAttachment {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  type      String
  title     String
  fileUrl   String?
  content   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Setting {
  id     String @id @default(cuid())
  userId String
  key    String
  value  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}
