generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  subjects      Subject[]
  studySessions StudySession[]
  questions     Question[]
  topics        Topic[]
  attachments   TopicAttachment[]
  settings      Setting[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subject {
  id          String    @id @default(cuid())
  userId      String
  name        String
  color       String    @default("#6366f1")
  goalMinutes Int       @default(60)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    StudySession[]
  questions   Question[]
  topics      Topic[]
}

model StudySession {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String?
  minutes     Int
  sessionType String   @default("timer")
  notes       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Question {
  id        String   @id @default(cuid())
  userId    String
  subjectId String?
  topic     String?
  total     Int      @default(0)
  correct   Int      @default(0)
  wrong     Int      @default(0)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model Topic {
  id          String    @id @default(cuid())
  userId      String
  subjectId   String?
  name        String
  studyDate   DateTime?
  completed   Boolean   @default(false)
  source      String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     Subject?  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  attachments TopicAttachment[]
}

model TopicAttachment {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  type      String
  title     String
  fileUrl   String?
  content   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model Setting {
  id     String @id @default(cuid())
  userId String
  key    String
  value  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}
